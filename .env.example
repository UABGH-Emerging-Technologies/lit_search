# ── lit_search environment template ──────────────────────────────────────
# You only need a .env if you do NOT have the shared /mnt/p/Secrets mount
# (e.g. running off-network), or if you run on the host via `make run` instead
# of Docker. With the mount + `docker compose up --build`, none of this is
# required.
#
# To use it:
#   1. cp .env.example .env
#   2. fill in the real values below
#   3. for Docker: in docker-compose.yml, comment each secret's `file:` line
#      and uncomment its `environment:` line (exactly one source per secret)
#
# Values are read by aiweb_common.manage_sensitive() via its env-var fallback.

# LLM proxy (frontend injects these into requests / Authorization header)
azure_proxy_key=
azure_proxy_endpoint=

# Backend data-source keys
libkey_api_key=
ncbi_api_key=

# ── Optional overrides (sane defaults exist; leave unset unless needed) ────
# OPENAI_COMPATIBLE_MODEL=gpt-4o
# LIT_ENDPOINT=http://localhost:8000   # backend URL for `make run` on the host
# LIT_API_PORT=8000                    # host port for the backend service
# LIT_STREAMLIT_PORT=8501              # host port for the frontend service
